# Copy to .env and fill in. See docs/12-setup-and-api-keys.md
# NEVER commit .env (it is gitignored).

# ---- Tier 1: required for the first local run (all no-card) ----
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ALIF_VOICE_ID=          # from ElevenLabs Voice Design (docs/11 §3)
TARANA_VOICE_ID=        # your chosen ElevenLabs voice
SARVAM_API_KEY=

# ---- Tier 2: recommended (no card except Azure) ----
GROQ_API_KEY=
TAVILY_API_KEY=
# AZURE_SPEECH_KEY=     # DEFERRED by decision (needs card); add before real usage
# AZURE_SPEECH_REGION=  # e.g. centralindia

# ---- local services (no keys) ----
OLLAMA_BASE_URL=http://localhost:11434
WHISPER_MODEL=large-v3  # use 'medium' or 'small' to save VRAM on the 8GB 4060

# ---- model selection (sensible defaults; override if needed) ----
GEMINI_MODEL=gemini-2.5-flash
ELEVENLABS_MODEL=eleven_v3
